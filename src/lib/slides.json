        { "id": "s6-cat3-hdr", "type": "text", "content": "HEDGING", "x": 5.16, "y": 1.88, "w": 2.0, "h": 0.4, "style": { "fontSize": 10, "bold": true, "color": "A78BFA", "align": "left", "charSpacing": 1.5 } },
        { "id": "s6-cat3-t0", "type": "text", "content": "Hedge accounting not executable", "x": 5.22, "y": 2.36, "w": 1.96, "h": 0.62, "style": { "fontSize": 11.5, "bold": true, "color": "FFFFFF", "align": "left" } },
        { "id": "s6-cat3-t1", "type": "text", "content": "B/S risk hedging blocked", "x": 5.22, "y": 3.08, "w": 1.96, "h": 0.62, "style": { "fontSize": 11.5, "bold": true, "color": "FFFFFF", "align": "left" } },
