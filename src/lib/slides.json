        { "id": "s6-cat4-hdr-bg", "type": "rect", "content": "", "x": 7.44, "y": 1.88, "w": 2.18, "h": 0.4, "style": { "bg": "162C44", "color": "162C44" } },
        { "id": "s6-cat4-hdr-bar", "type": "bar", "content": "", "x": 7.44, "y": 1.88, "w": 2.18, "h": 0.05, "style": { "bg": "2DD4BF", "color": "2DD4BF" } },
        { "id": "s6-cat4-hdr", "type": "text", "content": "RISK SCOPE", "x": 7.54, "y": 1.88, "w": 2.0, "h": 0.4, "style": { "fontSize": 10, "bold": true, "color": "2DD4BF", "align": "left", "charSpacing": 1.5 } },
        { "id": "s6-cat4-t0", "type": "text", "content": "Not all FX events captured", "x": 7.6, "y": 2.36, "w": 1.96, "h": 0.62, "style": { "fontSize": 11.5, "bold": true, "color": "FFFFFF", "align": "left" } },
        { "id": "s6-cat4-t1", "type": "text", "content": "VaR understates true risk", "x": 7.6, "y": 3.08, "w": 1.96, "h": 0.62, "style": { "fontSize": 11.5, "bold": true, "color": "FFFFFF", "align": "left" } },
        { "id": "s6-cat4-t2", "type": "text", "content": "Audit recon cannot be produced", "x": 7.6, "y": 3.8, "w": 1.96, "h": 0.62, "style": { "fontSize": 11.5, "bold": true, "color": "FFFFFF", "align": "left" } },
        { "id": "s6-summary-bg", "type": "rect", "content": "", "x": 0.3, "y": 4.64, "w": 9.4, "h": 0.5, "style": { "bg": "162C44", "color": "162C44" } },
        { "id": "s6-summary", "type": "text", "content": "Each of these is a current operational gap — not a future risk.", "x": 0.5, "y": 4.64, "w": 9.0, "h": 0.5, "style": { "fontSize": 13, "bold": true, "color": "CBD5E1", "italic": true, "align": "left" } },
