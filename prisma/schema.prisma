generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

// NextAuth required tables
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id              String            @id @default(cuid())
  name            String?
  email           String?           @unique
  emailVerified   DateTime?
  image           String?
  isSuperuser     Boolean           @default(false)
  accounts        Account[]
  sessions        Session[]
  presentations   Presentation[]
  knowledgeLayers KnowledgeLayer[]
  branches        KnowledgeBranch[]
  hubMemberships  HubMember[]
  // Billing (Stripe)
  plan               String    @default("free")
  stripeCustomerId   String?   @unique
  subscriptionId     String?
  subscriptionStatus String?
  currentPeriodStart DateTime?
  currentPeriodEnd   DateTime?
  usageRecords       UsageRecord[]
  deckComments       DeckComment[]
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
}

// A "knowledge branch" groups presentations that share the same knowledge
// layers and design system. Creating a presentation either starts a new
// branch or joins an existing one.
model KnowledgeBranch {
  id              String           @id @default(cuid())
  userId          String
  user            User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  name            String           @default("Untitled Branch")
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  presentations   Presentation[]
  knowledgeLayers KnowledgeLayer[]
  members         HubMember[]
  invites         HubInvite[]
  sourceDocuments SourceDocument[]
}

// Collaboration: who can access a Knowledge Hub and at what level.
model HubMember {
  id        String          @id @default(cuid())
  hubId     String
  hub       KnowledgeBranch @relation(fields: [hubId], references: [id], onDelete: Cascade)
  userId    String
  user      User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  role      String          @default("editor")
  createdAt DateTime        @default(now())

  @@unique([hubId, userId])
}

model HubInvite {
  id          String          @id @default(cuid())
  hubId       String
  hub         KnowledgeBranch @relation(fields: [hubId], references: [id], onDelete: Cascade)
  email       String
  role        String          @default("editor")
  token       String          @unique
  invitedById String
  status      String          @default("pending")
  createdAt   DateTime        @default(now())

  @@unique([hubId, email])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// App models
model Presentation {
  id                  String           @id @default(cuid())
  userId              String
  user                User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  branchId            String?
  branch              KnowledgeBranch? @relation(fields: [branchId], references: [id], onDelete: SetNull)
  name                String           @default("Untitled Presentation")
  slides              String // JSON string
  conversationHistory String         @default("[]") // JSON: ConversationMessage[]
  editorSession       String         @default("{}") // JSON: unfinished amendments / agent state
  activeSlideId       String?
  createdAt           DateTime       @default(now())
  updatedAt           DateTime       @updatedAt
  versions            SlideVersion[]
  decisions           DecisionRecord[]
  comments            DeckComment[]
}

model SlideVersion {
  id              String       @id @default(cuid())
  presentationId  String
  presentation    Presentation @relation(fields: [presentationId], references: [id], onDelete: Cascade)
  branchId        String?  // deck-timeline branch this snapshot belongs to
  branchLabel     String?  // denormalized branch name (rebuilds the branch list on load)
  parentVersionId String?  // predecessor in the timeline tree
  isBranchRoot    Boolean  @default(false)
  label          String?
  changeLog      String
  slides         String // JSON string
  decisionId     String?
  slideCount     Int
  changedSlideIds String // JSON string (array)
  actorId        String? // which user made this commit (audit trail)
  createdAt      DateTime     @default(now())
}

model KnowledgeLayer {
  id        String           @id @default(cuid())
  userId    String
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  branchId  String?
  branch    KnowledgeBranch? @relation(fields: [branchId], references: [id], onDelete: Cascade)
  type      String // style | terminology | stakeholder | workspace | custom
  name      String
  content   String
  enabled   Boolean  @default(true)
  source    String? // manual | template | inferred
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Per-billing-period token usage. One row per user per period; usage "resets"
// automatically when the periodKey changes (new Stripe cycle or new month).
model UsageRecord {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  periodKey  String
  tokensUsed Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([userId, periodKey])
}

model DecisionRecord {
  id                 String       @id @default(cuid())
  presentationId     String
  presentation       Presentation @relation(fields: [presentationId], references: [id], onDelete: Cascade)
  instruction        String
  proposedSummary    String
  proposedChanges    String // JSON string
  status             String       @default("pending") // accepted | rejected | pending
  rejectionReason    String? // why the user rejected (optional, scopes the memory)
  slideIds           String // JSON string
  selectedElementIds String // JSON string
  snapshotBefore     String? // JSON string
  actorId            String? // which user made this decision (audit trail)
  createdAt          DateTime     @default(now())
}

// Collaborator feedback on a deck — scoped to the whole deck, a slide, or an element.
// Included in LLM knowledge context so agents honor team notes.
model DeckComment {
  id             String       @id @default(cuid())
  presentationId String
  presentation   Presentation @relation(fields: [presentationId], references: [id], onDelete: Cascade)
  userId         String
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  slideId        String?
  elementId      String?
  /** Pin position on slide canvas (0–960 × 0–720 px). */
  pinX           Float?
  pinY           Float?
  content        String
  resolved       Boolean      @default(false)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@index([presentationId])
}

// ── Knowledge graph (Phase 0–1) ───────────────────────────────────────────────

model SourceDocument {
  id                   String           @id @default(cuid())
  branchId             String
  branch               KnowledgeBranch  @relation(fields: [branchId], references: [id], onDelete: Cascade)
  title                String
  fileType             String
  uploadedById         String
  blobUrl              String
  extractedTextBlobUrl String?
  /** Inline fallback when Vercel Blob is unavailable (serverless). */
  extractedText        String?
  status               String           @default("registered") // registered | parsed | extracted | failed
  error                String?
  createdAt            DateTime         @default(now())
  updatedAt            DateTime         @updatedAt
  chunks               DocumentChunk[]
  graphNodes           GraphNode[]
  graphVersions        GraphVersion[]

  @@index([branchId])
}

model DocumentChunk {
  id               String         @id @default(cuid())
  sourceDocumentId String
  sourceDocument   SourceDocument @relation(fields: [sourceDocumentId], references: [id], onDelete: Cascade)
  sectionTitle     String?
  text             String
  page             Int?
  charStart        Int?
  charEnd          Int?
  ordinal          Int

  @@index([sourceDocumentId])
}

model GraphNode {
  id               String          @id @default(cuid())
  branchId         String
  type             String // SourceDocument | DocumentChunk | Topic | Claim | Metric
  name             String
  description      String?
  status           String          @default("candidate") // candidate | approved | rejected
  confidence       Float           @default(0.5)
  properties       String          @default("{}") // JSON
  createdBy        String          @default("ai_agent") // ai_agent | user
  sourceDocumentId String?
  sourceDocument   SourceDocument? @relation(fields: [sourceDocumentId], references: [id], onDelete: Cascade)
  presentationId   String?
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  edgesFrom        GraphEdge[]     @relation("EdgeFrom")
  edgesTo          GraphEdge[]     @relation("EdgeTo")

  @@index([branchId, type, status])
  @@index([sourceDocumentId])
  @@index([presentationId])
}

model GraphEdge {
  id           String    @id @default(cuid())
  branchId     String
  fromNodeId   String
  fromNode     GraphNode @relation("EdgeFrom", fields: [fromNodeId], references: [id], onDelete: Cascade)
  toNodeId     String
  toNode       GraphNode @relation("EdgeTo", fields: [toNodeId], references: [id], onDelete: Cascade)
  type         String // SUPPORTED_BY | ABOUT | PART_OF
  confidence   Float     @default(0.5)
  evidenceText String?
  properties   String    @default("{}") // JSON
  createdAt    DateTime  @default(now())

  @@index([branchId])
  @@index([fromNodeId, toNodeId, type])
}

model GraphVersion {
  id               String          @id @default(cuid())
  branchId         String
  sourceDocumentId String?
  sourceDocument   SourceDocument? @relation(fields: [sourceDocumentId], references: [id], onDelete: SetNull)
  presentationId   String?
  summary          String
  nodeCount        Int
  edgeCount        Int
  createdAt        DateTime        @default(now())

  @@index([branchId])
}
