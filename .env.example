# Copy to .env.local for development and set real values.
# In Vercel, add each of these under Project Settings → Environment Variables.

# ── Database ──────────────────────────────────────────────────────────────────
# Local dev: file-based SQLite. Production: Turso libSQL URL.
#   Local:      file:./prisma/dev.db
#   Production:  libsql://your-db-name-org.turso.io
DATABASE_URL="file:./prisma/dev.db"
# Turso auth token. Empty for local file DBs; required for libsql:// URLs.
DATABASE_AUTH_TOKEN=""

# ── AI providers ──────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=""
# Execute phase (planning, content, small edits): Haiku 4.5
ANTHROPIC_CHEAP_MODEL="claude-haiku-4-5"
# Review phase (layout/design verify & fix after first apply): Sonnet 4.6
ANTHROPIC_MODEL="claude-sonnet-4-6"
# Optional: classifier router model (defaults to ANTHROPIC_CHEAP_MODEL)
# ANTHROPIC_ROUTER_MODEL="claude-haiku-4-5"
OPENAI_API_KEY=""

# ── App / storage ─────────────────────────────────────────────────────────────
STORAGE_PATH="./storage"
# Vercel Blob — raw source uploads + extracted text artifacts (Knowledge Graph).
# Required in production/Vercel. Local dev works without it (files go to STORAGE_PATH).
BLOB_READ_WRITE_TOKEN=""
# Optional: graph extraction pacing (Anthropic rate limits on low tiers).
# GRAPH_EXTRACT_BATCH_SIZE=2
# GRAPH_EXTRACT_DELAY_MS=6500

# ── Billing quotas (optional — code has defaults) ─────────────────────────────
# DECKPILOT_FREE_TOKENS=200000
# DECKPILOT_PRO_TOKENS=2000000
# DECKPILOT_MAX_TOKENS=5000000

# ── Adobe PDF import (optional — PDF→PPTX via Adobe PDF Services) ─────────────
# PDF_SERVICES_CLIENT_ID=""
# PDF_SERVICES_CLIENT_SECRET=""
# ADOBE_TIMEOUT_MS=180000

# ── Auth (NextAuth) ───────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
AUTH_SECRET=""
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
# Public site URL. Local: http://localhost:3000  Production: https://slidio.app
NEXT_PUBLIC_APP_URL="http://localhost:3000"
# Must match NEXT_PUBLIC_APP_URL and the Google OAuth redirect URI.
AUTH_URL="http://localhost:3000"
# Only enable in local dev behind a TLS-inspecting proxy. Never set in production.
AUTH_ALLOW_INSECURE_TLS="true"
# Optional: POST every new free-plan registration to a Slack/Discord/generic webhook.
SIGNUP_WEBHOOK_URL=""
# Comma-separated emails that get owner access on every hub (dev/testing).
SUPERUSER_EMAILS="dev@local.test,kirillshavlovskiy@gmail.com"

# ── Stripe billing ────────────────────────────────────────────────────────────
# Use sk_test_/pk_test_ in development to avoid real charges.
STRIPE_SECRET_KEY=""
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=""
# From the Stripe dashboard webhook endpoint, or `stripe listen` locally.
STRIPE_WEBHOOK_SECRET=""
# Generate with: node scripts/setup-stripe.mjs
STRIPE_PRICE_PRO_MONTHLY=""
STRIPE_PRICE_PRO_YEARLY=""
STRIPE_PRICE_MAX_MONTHLY=""
STRIPE_PRICE_MAX_YEARLY=""
