# Copy to .env.local for development and set real values.
# In Vercel, add each of these under Project Settings → Environment Variables.

# ── Database ──────────────────────────────────────────────────────────────────
# Local dev: file-based SQLite. Production: Turso libSQL URL.
#   Local:      file:./prisma/dev.db
#   Production:  libsql://your-db-name-org.turso.io
DATABASE_URL="file:./prisma/dev.db"
# Turso auth token. Empty for local file DBs; required for libsql:// URLs.
DATABASE_AUTH_TOKEN=""

# ── AI providers ──────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=""
OPENAI_API_KEY=""

# ── App / storage ─────────────────────────────────────────────────────────────
STORAGE_PATH="./storage"

# ── Auth (NextAuth) ───────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
AUTH_SECRET=""
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
# Public site URL. Local: http://localhost:3000  Production: https://slidio.app
NEXT_PUBLIC_APP_URL="http://localhost:3000"
# Must match NEXT_PUBLIC_APP_URL and the Google OAuth redirect URI.
AUTH_URL="http://localhost:3000"
# Only enable in local dev behind a TLS-inspecting proxy. Never set in production.
AUTH_ALLOW_INSECURE_TLS="true"

# ── Stripe billing ────────────────────────────────────────────────────────────
# Use sk_test_/pk_test_ in development to avoid real charges.
STRIPE_SECRET_KEY=""
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=""
# From the Stripe dashboard webhook endpoint, or `stripe listen` locally.
STRIPE_WEBHOOK_SECRET=""
# Generate with: node scripts/setup-stripe.mjs
STRIPE_PRICE_PRO_MONTHLY=""
STRIPE_PRICE_PRO_YEARLY=""
STRIPE_PRICE_MAX_MONTHLY=""
STRIPE_PRICE_MAX_YEARLY=""
